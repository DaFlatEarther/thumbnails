# Kie API key for Nano Banana Pro image generation.
# Get one from https://kie.ai
KIE_API_KEY=sk-your-key-here

# Optional: if set, /mcp requires `Authorization: Bearer <token>` on every
# request. Leave unset for local dev; set on any shared/hosted deployment so
# random visitors can't burn Kie credits.
THUMBNAILS_MCP_TOKEN=
